<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dlvs.controller.DangNhapController">
   <children>
      <ImageView fitHeight="150.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@locphattai.jpg" />
         </image>
      </ImageView>
      <Label text="ĐẠI LÝ VÉ SỐ LỘC PHÁT TÀI" textFill="#c62828">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label text="Chào mừng quý khách đến với Lộc Phát Tài" textFill="#fbc02d">
         <font>
            <Font name="System Bold Italic" size="14.0" />
         </font>
      </Label>
      <Label text="HỆ THỐNG ĐĂNG NHẬP" textFill="#5b5b5b">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <VBox maxWidth="250.0" spacing="15.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Tài khoản:" />
                  <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label text="Mật khẩu:" />
                  <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" />
               </children>
            </VBox>
            <Button fx:id="btnDangNhap" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDangNhap" prefHeight="40.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Đăng Nhập" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
